{
  "version": 4,
  "configurations": [
    {
      "name": "Windows-Flutter-Runner",
      "includePath": [
        "${workspaceFolder}/windows",
        "${workspaceFolder}/windows/flutter/ephemeral",
        "${workspaceFolder}/windows/flutter/ephemeral/.plugin_symlinks/**",
        "${env:FLUTTER_ROOT}/bin/cache/artifacts/engine/windows-x64",
        "${env:FLUTTER_ROOT}/bin/cache/artifacts/engine/windows-x64/cpp_client_wrapper/include"
      ],
      "defines": [
        "UNICODE",
        "_UNICODE"
      ],
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "windows-msvc-x64"
    }
  ]
}
